# ---------- Helper Functions ----------

# Create a clickable terminal hyperlink using OSC 8 escape sequence
# Falls back to plain "label (url)" if terminal doesn't support it
# Usage: link "https://example.com" "Click here"
link() {
    local url="$1"
    local label="${2:-$url}"
    # OSC 8 hyperlink: supported by most modern terminals
    printf '\033]8;;%s\033\\%s\033]8;;\033\\' "$url" "$label"
}

# Normalize protocol value: trim whitespace and convert to lowercase
# Returns empty string for empty/whitespace-only input
normalize_protocol() {
    local value="$1"

    # Return empty for empty string
    [[ -z "$value" && -n "${value+x}" ]] && { echo ""; return 0; }

    # Trim whitespace and convert to lowercase using bash 3.2 compatible approach
    # Using parameter expansion for trimming (available in bash 3.2)
    local trimmed="${value##[[:space:]]*}"  # Remove leading whitespace
    trimmed="${trimmed%%[[:space:]]*}"     # Remove trailing whitespace

    # Return empty for whitespace-only input
    [[ -z "$trimmed" ]] && { echo ""; return 0; }

    # Convert to lowercase - use tr as it's bash 3.2 compatible
    # Note: This spawns a subprocess but is unavoidable in bash 3.2
    echo "$trimmed" | tr '[:upper:]' '[:lower:]'
}

# Validate protocol value against whitelist and warn if invalid
# Returns sanitized protocol (whitelist or default)
validate_protocol() {
    local provider="$1"
    local protocol="$2"

    # Valid protocols whitelist
    local valid_openai="openai"
    local valid_anthropic="anthropic"

    # If protocol is empty after normalization, it will be defaulted later
    [[ -z "$protocol" ]] && { echo ""; return 0; }

    # Check if valid
    if [[ "$protocol" == "$valid_openai" ]] || [[ "$protocol" == "$valid_anthropic" ]]; then
        echo "$protocol"
        return 0
    fi

    # Invalid protocol - emit warning and return empty (will be defaulted to openai)
    echo "⚠️  Warning: Invalid protocol '$protocol' for provider '$provider'. Valid values: openai, anthropic. Defaulting to 'openai'." >&2
    echo ""
    return 0
}

# Set default protocol for providers that don't have one explicitly set
# Only applies to enabled providers to avoid unnecessary work
apply_default_protocols() {
    local provider
    local existing_protocol
    local provider_enabled
    local -a base_url_keys

    get_provider_keys "PROVIDER_BASE_URLS"
    base_url_keys=("${REPLY_KEYS[@]}")
    for provider in "${base_url_keys[@]}"; do
        [[ -z "$provider" ]] && continue

        # Check if provider has a protocol set
        get_provider_value "PROVIDER_PROTOCOLS" "$provider"; existing_protocol="$REPLY"

        # Only set default if protocol is empty and provider is enabled
        # Check if provider is enabled (defaults to true if not set)
        if [[ -z "$existing_protocol" ]]; then
            # Preserve original semantics: the old `|| echo "true"` fired only on a
            # nonzero exit (which never occurred here), so an unset enabled -> empty.
            get_provider_value "PROVIDER_ENABLED" "$provider"; provider_enabled="$REPLY"

            # Only set default for enabled providers
            if [[ "$provider_enabled" == "true" ]]; then
                set_provider_value "PROVIDER_PROTOCOLS" "$provider" "openai"
                debug "PROVIDER_PROTOCOLS[$provider] defaulted to 'openai'"
            else
                debug "PROVIDER_PROTOCOLS[$provider] not defaulted (provider disabled)"
            fi
        fi
    done
}

mask() {
    local input="$1"
    [[ -z "$input" ]] && { echo "∅"; return; }
    [[ ${#input} -le 2 ]] && { echo "$input"; return; }

    # For strings of 3-4 characters, mask first character only
    if [[ ${#input} -le 4 ]]; then
        echo "•${input:1}"
        return
    fi

    # For strings > 4 characters, mask all but last 4 characters
    local masked=""
    local i
    for ((i=0; i<${#input}-4; i++)); do
        masked+="•"
    done
    masked+="${input: -4}"
    echo "$masked"
}

host_from_url() {
    awk -F/ '{print $3}' <<<"$1"
}

# Validate provider name format
validate_provider_name() {
    local name="$1"
    local valid_name_pattern="^[a-zA-Z0-9_-]+$"
    # Use C locale for consistent ASCII-only character class matching
    if LC_ALL=C; [[ ! "$name" =~ $valid_name_pattern ]]; then
        echo "Error: Invalid provider name '$name'. Only letters, numbers, underscores, and hyphens are allowed." >&2
        return 1
    fi
    return 0
}

# Sanitize configuration values to prevent injection
sanitize_config_value() {
    local value="$1"
    # Remove potential command substitution and other dangerous patterns
    value="${value//\$(/}"
    value="${value//\`/}"
    value="${value//\$/}"
    value="${value//;/}"
    value="${value//&/}"
    value="${value//|/}"
    echo "$value"
}

# Validate provider exists and is enabled
validate_provider() {
    local provider="$1"
    debug "Validating provider: $provider"
    
    # Check if provider exists
    if ! has_provider_key "PROVIDER_BASE_URLS" "$provider"; then
        debug "Provider not found: $provider"
        return 1
    fi
    
    # Check if provider is enabled
    local provider_enabled
    get_provider_value "PROVIDER_ENABLED" "$provider"; provider_enabled="$REPLY"
    if [[ "${provider_enabled:-true}" != "true" ]]; then
        debug "Provider disabled: $provider"
        return 2
    fi
    
    debug "Provider validation successful: $provider"
    return 0
}

# ---------- Commands ----------

# Set a single provider's environment variables
# Returns 0 on success, 1 on failure
set_single_provider() {
    local provider="$1"

    # Validate provider name format
    if ! validate_provider_name "$provider"; then
        return 1
    fi

    # Validate provider
    if ! validate_provider "$provider"; then
        case $? in
            1) echo "❌ Unknown provider: $provider" ;;
            2) echo "❌ Provider disabled: $provider" ;;
        esac
        echo "Available providers: ${AVAILABLE_PROVIDERS[*]}"
        echo
        return 1
    fi

    # Get protocol for this provider (defaults to "openai")
    local protocol
    get_provider_value "PROVIDER_PROTOCOLS" "$provider"; protocol="${REPLY:-openai}"

    local key_var model base key auth_token_var auth_token
    get_provider_value "PROVIDER_API_KEY_VARS" "$provider"; key_var="$REPLY"
    get_provider_value "PROVIDER_BASE_URLS" "$provider"; base="$REPLY"
    get_provider_value "PROVIDER_DEFAULT_MODELS" "$provider"; model="${OPENAI_MODEL_OVERRIDE:-$REPLY}"
    if [[ -n "$key_var" ]]; then
        get_var_value "$key_var"; key="$REPLY"
    else
        key=""
    fi

    # Get auth token for Anthropic protocol
    if [[ "$protocol" == "anthropic" ]]; then
        get_provider_value "PROVIDER_AUTH_TOKENS" "$provider"; auth_token_var="$REPLY"
        if [[ -n "$auth_token_var" ]]; then
            get_var_value "$auth_token_var"; auth_token="$REPLY"
        fi
    fi

    local key_set="no" auth_token_set="no"
    [[ -n "$key" ]] && key_set="yes"
    [[ -n "$auth_token" ]] && auth_token_set="yes"
    debug "Resolving environment for provider $provider:"
    debug "  protocol=$protocol"
    debug "  key_var=$key_var"
    debug "  auth_token_var=$auth_token_var"
    debug "  base=$base"
    debug "  model=$model"
    debug "  key_set=$key_set"
    debug "  auth_token_set=$auth_token_set"

    # For anthropic protocol, either api_key_var or auth_token_var is sufficient
    if [[ "$protocol" == "anthropic" ]]; then
        if [[ -z "$key_var" && -z "$auth_token_var" ]]; then
            echo "❌ Invalid provider configuration: missing api_key_var or auth_token_var for $provider"
            echo
            return 1
        fi
        if [[ -z "$key" && -z "$auth_token" ]]; then
            local missing_vars=""
            [[ -n "$key_var" && -z "$key" ]] && missing_vars="$key_var"
            [[ -n "$auth_token_var" && -z "$auth_token" ]] && {
                [[ -n "$missing_vars" ]] && missing_vars="$missing_vars or "
                missing_vars="${missing_vars}${auth_token_var}"
            }
            echo "⚠️  No credentials found for $provider. Set $missing_vars in your shell profile."
            local signup_url
            get_provider_value "PROVIDER_SIGNUP_URLS" "$provider"; signup_url="$REPLY"
            if [[ -n "$signup_url" ]]; then
                printf '   🔑 Get an API key: %s\n' "$(link "$signup_url" "$signup_url")"
            fi
            echo
            return 1
        fi
    else
        # OpenAI protocol requires api_key_var
        if [[ -z "$key_var" ]]; then
            echo "❌ Invalid provider configuration: missing API key variable for $provider"
            echo
            return 1
        elif [[ -z "$key" ]]; then
            echo "⚠️  No API key found for $provider. Set $key_var in your shell profile."
            local signup_url
            get_provider_value "PROVIDER_SIGNUP_URLS" "$provider"; signup_url="$REPLY"
            if [[ -n "$signup_url" ]]; then
                printf '   🔑 Get an API key: %s\n' "$(link "$signup_url" "$signup_url")"
            fi
            echo
            return 1
        fi
    fi

    if [[ -z "$base" || -z "$model" ]]; then
        echo "❌ Missing base URL or model for $provider"
        echo
        return 1
    fi

    # Export protocol-specific variables
    local host
    if [[ "$protocol" == "anthropic" ]]; then
        # Export Anthropic-specific variables (only set what's configured)
        export ANTHROPIC_BASE_URL="$base"
        export ANTHROPIC_MODEL="$model"
        # Set Claude Code specific model variables to the provider's model
        export ANTHROPIC_DEFAULT_OPUS_MODEL="$model"
        export ANTHROPIC_DEFAULT_SONNET_MODEL="$model"
        export ANTHROPIC_DEFAULT_HAIKU_MODEL="$model"
        export CLAUDE_CODE_SUBAGENT_MODEL="$model"
        export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC="${CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC:-false}"

        if [[ -n "$key" ]]; then
            export ANTHROPIC_API_KEY="$key"
        fi
        if [[ -n "$auth_token" ]]; then
            export ANTHROPIC_AUTH_TOKEN="$auth_token"
            # Also set ANTHROPIC_API_KEY from auth_token if not already set
            export ANTHROPIC_API_KEY="${ANTHROPIC_API_KEY:-$auth_token}"
        fi
        export LLM_PROVIDER="$provider"
        export LLM_PROTOCOL="$protocol"

        host=$(host_from_url "$ANTHROPIC_BASE_URL")
        local cred_display=""
        [[ -n "$key" ]] && cred_display="key=$(mask "$key")"
        [[ -n "$auth_token" ]] && {
            [[ -n "$cred_display" ]] && cred_display="$cred_display "
            cred_display="${cred_display}auth_token=$(mask "$auth_token")"
        }
        echo "✅ Set: provider=$LLM_PROVIDER protocol=$protocol host=$host model=$ANTHROPIC_MODEL $cred_display"
        echo "🔧 Additional Claude Code variables set: ANTHROPIC_DEFAULT_OPUS_MODEL=$ANTHROPIC_DEFAULT_OPUS_MODEL, ANTHROPIC_DEFAULT_SONNET_MODEL=$ANTHROPIC_DEFAULT_SONNET_MODEL, ANTHROPIC_DEFAULT_HAIKU_MODEL=$ANTHROPIC_DEFAULT_HAIKU_MODEL, CLAUDE_CODE_SUBAGENT_MODEL=$CLAUDE_CODE_SUBAGENT_MODEL"
    else
        # Export OpenAI-compatible variables (default)
        export OPENAI_API_KEY="$key"
        export OPENAI_BASE_URL="$base"
        export OPENAI_MODEL="$model"
        export LLM_PROVIDER="$provider"
        export LLM_PROTOCOL="$protocol"

        host=$(host_from_url "$OPENAI_BASE_URL")
        echo "✅ Set: provider=$LLM_PROVIDER protocol=$protocol host=$host model=$OPENAI_MODEL key=$(mask "$OPENAI_API_KEY")"
    fi
    return 0
}

# Set multiple providers from a comma-separated list
set_multiple_providers() {
    local provider_list="$1"
    local failed=0
    local count=0

    # Split comma-separated list and set each provider
    local provider
    while IFS= read -r provider; do
        # Trim whitespace
        provider="$(echo "$provider" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
        [[ -z "$provider" ]] && continue
        ((count+=1))
        if ! set_single_provider "$provider"; then
            ((failed+=1))
        fi
    done <<< "$(echo "$provider_list" | tr ',' '\n')"

    if [[ "$count" -gt 1 ]]; then
        # For multi-provider sets, update LLM_PROVIDER to show all
        export LLM_PROVIDER="$provider_list"
    fi

    echo
    [[ "$failed" -eq 0 ]] && return 0 || return 1
}

cmd_set() {
    local input="$1"
    if [[ -z "$input" ]]; then
        echo "Usage: source llm-env set <provider|group|provider1,provider2>"
        echo "Available providers: ${AVAILABLE_PROVIDERS[*]}"
        if [[ ${#AVAILABLE_GROUPS[@]} -gt 0 ]]; then
            echo "Available groups: ${AVAILABLE_GROUPS[*]}"
        fi
        echo
        return 1
    fi

    # Check if input is a group name
    local group_providers
    get_provider_value "PROVIDER_GROUPS" "$input"; group_providers="$REPLY"
    if [[ -n "$group_providers" ]]; then
        debug "Setting group '$input' with providers: $group_providers"
        set_multiple_providers "$group_providers"
        return $?
    fi

    # Check if input contains commas (multi-provider set)
    if [[ "$input" == *,* ]]; then
        debug "Setting comma-separated providers: $input"
        set_multiple_providers "$input"
        return $?
    fi

    # Single provider
    set_single_provider "$input"
    local rc=$?
    echo
    return $rc
}

cmd_unset() {
    # Check if anything is actually set
    local has_openai=false has_anthropic=false
    [[ -n "${OPENAI_BASE_URL:-}" || -n "${OPENAI_MODEL:-}" || -n "${OPENAI_API_KEY:-}" ]] && has_openai=true
    [[ -n "${ANTHROPIC_BASE_URL:-}" || -n "${ANTHROPIC_MODEL:-}" || -n "${ANTHROPIC_API_KEY:-}" || -n "${ANTHROPIC_AUTH_TOKEN:-}" ]] && has_anthropic=true

    if [[ -z "${LLM_PROVIDER:-}" && "$has_openai" == false && "$has_anthropic" == false ]]; then
        echo "ℹ️  Nothing to unset — no LLM environment variables are currently set."
        echo
        return 0
    fi

    local prev_p="${LLM_PROVIDER:-}"
    local prev_protocol="${LLM_PROTOCOL:-openai}"

    # Capture previous state for both protocols
    local prev_openai_host prev_openai_model prev_anthropic_host prev_anthropic_model
    prev_openai_host=$(host_from_url "${OPENAI_BASE_URL:-}")
    prev_openai_model="${OPENAI_MODEL:-}"
    prev_anthropic_host=$(host_from_url "${ANTHROPIC_BASE_URL:-}")
    prev_anthropic_model="${ANTHROPIC_MODEL:-}"

    # Unset all protocol variables (both OpenAI and Anthropic)
    unset OPENAI_API_KEY OPENAI_BASE_URL OPENAI_MODEL
    unset ANTHROPIC_API_KEY ANTHROPIC_AUTH_TOKEN ANTHROPIC_BASE_URL ANTHROPIC_MODEL
    unset ANTHROPIC_DEFAULT_OPUS_MODEL ANTHROPIC_DEFAULT_SONNET_MODEL ANTHROPIC_DEFAULT_HAIKU_MODEL
    unset CLAUDE_CODE_SUBAGENT_MODEL CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC
    unset LLM_PROVIDER LLM_PROTOCOL

    echo "🗑️ Unset LLM environment variables."
    if [[ -n "$prev_p" ]]; then
        echo "   Provider : $prev_p (protocol: $prev_protocol)"
    fi
    if [[ "$has_openai" == true ]]; then
        echo "   OpenAI   : host=${prev_openai_host:-∅} model=${prev_openai_model:-∅}"
    fi
    if [[ "$has_anthropic" == true ]]; then
        echo "   Anthropic: host=${prev_anthropic_host:-∅} model=${prev_anthropic_model:-∅}"
    fi
    echo
}

cmd_list() {
    local show_all=false
    [[ "$1" == "--all" ]] && show_all=true

    # Reload configuration to ensure we have the latest providers
    init_config

    echo "Available providers:"
    echo

    local providers_to_show=()
    if $show_all; then
        # Show all providers (enabled and disabled)
        get_provider_keys "PROVIDER_BASE_URLS"
        local _p
        for _p in "${REPLY_KEYS[@]}"; do
            [[ -n "$_p" ]] && providers_to_show+=("$_p")
        done
    else
        # Show only enabled providers
        providers_to_show=("${AVAILABLE_PROVIDERS[@]}")
    fi

    # Declare loop variables outside the loop for zsh compatibility
    local mark base model key_var have_key description enabled_status provider_enabled protocol key_val
    for provider in "${providers_to_show[@]}"; do
        mark=" "
        [[ "$provider" == "$LLM_PROVIDER" ]] && mark="*"

        get_provider_value "PROVIDER_BASE_URLS" "$provider"; base="$REPLY"
        get_provider_value "PROVIDER_DEFAULT_MODELS" "$provider"; model="$REPLY"
        get_provider_value "PROVIDER_API_KEY_VARS" "$provider"; key_var="$REPLY"
        get_provider_value "PROVIDER_DESCRIPTIONS" "$provider"; description="$REPLY"
        get_provider_value "PROVIDER_PROTOCOLS" "$provider"; protocol="${REPLY:-openai}"

        have_key="no"
        if [[ -n "$key_var" ]]; then
            get_var_value "$key_var"; key_val="$REPLY"
            [[ -n "$key_val" ]] && have_key="yes"
        fi

        # Show disabled status if showing all providers
        enabled_status=""
        get_provider_value "PROVIDER_ENABLED" "$provider"; provider_enabled="$REPLY"
        if $show_all && [[ "${provider_enabled:-true}" != "true" ]]; then
            enabled_status=" (disabled)"
        fi

        printf " %s %-12s  %-9s  %-30s  %-24s  key:%-3s  %s%s\n" \
            "$mark" "$provider" "$protocol" "$base" "$model" "$have_key" "$description" "$enabled_status"
    done
    [[ -n "$LLM_PROVIDER" ]] && echo; echo "* current provider"

    # Show groups if any are defined
    if [[ ${#AVAILABLE_GROUPS[@]} -gt 0 ]]; then
        echo
        echo "Provider groups:"
        echo
        local group_name group_providers
        for group_name in "${AVAILABLE_GROUPS[@]}"; do
            get_provider_value "PROVIDER_GROUPS" "$group_name"; group_providers="$REPLY"
            printf "   %-12s  → %s\n" "$group_name" "$group_providers"
        done
    fi

    echo
    return 0  # Explicit success return
}

cmd_show() {
    local current_protocol="${LLM_PROTOCOL:-openai}"

    # Detect which protocols have variables set
    local has_openai=false has_anthropic=false
    [[ -n "${OPENAI_BASE_URL:-}" || -n "${OPENAI_MODEL:-}" || -n "${OPENAI_API_KEY:-}" ]] && has_openai=true
    [[ -n "${ANTHROPIC_BASE_URL:-}" || -n "${ANTHROPIC_MODEL:-}" || -n "${ANTHROPIC_API_KEY:-}" || -n "${ANTHROPIC_AUTH_TOKEN:-}" ]] && has_anthropic=true

    echo "Current environment:"
    echo "  LLM_PROVIDER       = ${LLM_PROVIDER:-∅}"
    echo "  LLM_PROTOCOL       = ${current_protocol}"

    # Show OpenAI variables if set, or if it's the active protocol
    if [[ "$has_openai" == true || "$current_protocol" == "openai" ]]; then
        echo "  OPENAI_BASE_URL    = ${OPENAI_BASE_URL:-∅}"
        echo "  OPENAI_MODEL       = ${OPENAI_MODEL:-∅}"
        echo "  OPENAI_API_KEY     = $(mask "${OPENAI_API_KEY:-}")"
    fi

    # Show Anthropic variables if set, or if it's the active protocol
    if [[ "$has_anthropic" == true || "$current_protocol" == "anthropic" ]]; then
        echo "  ANTHROPIC_BASE_URL = ${ANTHROPIC_BASE_URL:-∅}"
        echo "  ANTHROPIC_MODEL    = ${ANTHROPIC_MODEL:-∅}"
        echo "  ANTHROPIC_API_KEY  = $(mask "${ANTHROPIC_API_KEY:-}")"
        echo "  ANTHROPIC_AUTH_TOKEN = $(mask "${ANTHROPIC_AUTH_TOKEN:-}")"
    fi

    # Show configuration source
    while IFS= read -r config_file; do
        if [[ -f "$config_file" ]]; then
            echo "  Config file        = $config_file"
            break
        fi
    done < <(get_config_locations)
    echo
}

cmd_config() {
    local subcmd="$1"
    shift
    
    case "$subcmd" in
        init)
            cmd_config_init "$@"
            ;;
        edit)
            cmd_config_edit "$@"
            ;;
        add)
            cmd_config_add "$@"
            ;;
        remove)
            cmd_config_remove "$@"
            ;;
        validate)
            cmd_config_validate "$@"
            ;;
        backup)
            cmd_config_backup "$@"
            ;;
        restore)
            cmd_config_restore "$@"
            ;;
        bulk)
            cmd_config_bulk "$@"
            ;;
        *)
            echo "Usage: source llm-env config {init|edit|add|remove|validate|backup|restore|bulk}"
            echo "  init              Create user configuration file"
            echo "  edit              Edit user configuration file"
            echo "  add <provider>    Add a new provider interactively"
            echo "  remove <provider> Remove a provider"
            echo "  validate          Validate configuration file"
            echo "  backup            Create a backup of configuration"
            echo "  restore <file>    Restore configuration from backup"
            echo "  bulk <action> <providers...>  Perform bulk operations (enable|disable)"
            ;;
    esac
}

cmd_config_init() {
    local user_config
    user_config="$(get_user_config_path)"

    if [[ -f "$user_config" ]]; then
        echo "⚠️  Configuration file already exists: $user_config"
        read -p "Overwrite? (y/N): " -n 1 -r
        echo
        echo
        local yes_pattern="^[Yy]$"
        [[ ! $REPLY =~ $yes_pattern ]] && return 1
    fi

    # Create directory if it doesn't exist
    mkdir -p "$(dirname "$user_config")"

    # Try to copy from system/repo config first (excluding user config path)
    local default_config=""
    local script_dir_config
    script_dir_config="$(get_script_dir)/config/llm-env.conf"

    if [[ -f "/usr/local/etc/llm-env/config.conf" ]]; then
        default_config="/usr/local/etc/llm-env/config.conf"
    elif [[ -f "$script_dir_config" ]]; then
        default_config="$script_dir_config"
    fi

    if [[ -n "$default_config" ]]; then
        cp "$default_config" "$user_config"
        echo "✅ Created user configuration: $user_config"
        echo "💡 Edit this file to customize your providers and models"
        echo
    else
        # Generate default config inline (matches installer behavior)
        cat > "$user_config" << 'EOF'
# LLM Environment Manager Configuration
# This file defines available LLM providers and their settings

[openai]
base_url=https://api.openai.com/v1
api_key_var=LLM_OPENAI_API_KEY
