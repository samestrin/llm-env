cmd_config_edit() {
    local user_config
    user_config="$(get_user_config_path)"
    
    if [[ ! -f "${user_config}" ]]; then
        echo "⚠️  User configuration not found. Creating it first..."
        echo
        cmd_config_init || return 1
    fi
    
    # Use user's preferred editor
    local editor="${EDITOR:-${VISUAL:-nano}}"
    "$editor" "$user_config"
    
    echo "💡 Run 'source llm-env config validate' to check your configuration"
    echo
}

cmd_config_add() {
    local provider="$1"
    if [[ -z "$provider" ]]; then
        echo "Usage: source llm-env config add <provider_name>"
        return 1
    fi
    
    # Validate provider name format
    if ! validate_provider_name "$provider"; then
        return 1
    fi
    
    echo "Adding new provider: $provider"
    echo "Please provide the following information:"
    
    # Set timeout for read operations
    local TMOUT=30
    read -r -t $TMOUT -p "Base URL: " base_url || { echo "Timeout reached"; return 1; }
    read -r -t $TMOUT -p "API Key Environment Variable: " api_key_var || { echo "Timeout reached"; return 1; }
    read -r -t $TMOUT -p "Default Model: " default_model || { echo "Timeout reached"; return 1; }
    read -r -t $TMOUT -p "Description (optional): " description || { echo "Timeout reached"; return 1; }
    
    # Sanitize input values
    base_url=$(sanitize_config_value "$base_url")
    api_key_var=$(sanitize_config_value "$api_key_var")
    default_model=$(sanitize_config_value "$default_model")
    description=$(sanitize_config_value "$description")
    
    local user_config
    user_config="$(get_user_config_path)"
    
    # Create user config if it doesn't exist
    if [[ ! -f "$user_config" ]]; then
        cmd_config_init || return 1
    fi
    
    # Append new provider
    {
        echo ""
        echo "[$provider]"
        echo "base_url=$base_url"
        echo "api_key_var=$api_key_var"
        echo "default_model=$default_model"
        [[ -n "$description" ]] && echo "description=$description"
        echo "enabled=true"
    } >> "$user_config"
    
    echo "✅ Added provider '$provider' to $user_config"
    echo "💡 Don't forget to set $api_key_var in your shell profile"
}

cmd_config_remove() {
    local provider="$1"
    if [[ -z "$provider" ]]; then
        echo "Usage: source llm-env config remove <provider_name>"
        return 1
    fi
    
    # Validate provider name format
    if ! validate_provider_name "$provider"; then
        return 1
    fi
    
    local user_config
    user_config="$(get_user_config_path)"
    
    if [[ ! -f "$user_config" ]]; then
        echo "❌ User configuration not found: $user_config"
        return 1
    fi
    
    # Create backup
    cp "$user_config" "$user_config.backup"
    
    # Remove provider section
    awk -v provider="$provider" '
        BEGIN { in_section = 0 }
        /^\[/ { 
            if ($0 == "[" provider "]") {
                in_section = 1
                next
            } else {
                in_section = 0
            }
        }
        !in_section { print }
    ' "$user_config.backup" > "$user_config"
    
    echo "✅ Removed provider '$provider' from $user_config"
    echo "💡 Backup saved as $user_config.backup"
}

cmd_test() {
    local provider="$1"
    if [[ -z "$provider" ]]; then
        echo "Usage: source llm-env test <provider>"
        echo "Available providers: ${AVAILABLE_PROVIDERS[*]}"
        return 1
    fi

    # Validate provider name format
    if ! validate_provider_name "$provider"; then
        return 1
    fi

    # Validate provider
    validate_provider "$provider"
    local validate_result=$?
    if [[ $validate_result -ne 0 ]]; then
        case $validate_result in
            1) echo "❌ Unknown provider: $provider" ;;
            2) echo "❌ Provider disabled: $provider" ;;
        esac
        echo "Available providers: ${AVAILABLE_PROVIDERS[*]}"
        return 1
    fi

    # Get protocol for this provider (defaults to "openai")
    local protocol
    protocol="$(get_provider_value "PROVIDER_PROTOCOLS" "$provider")"
    protocol="${protocol:-openai}"

    echo "🧪 Testing provider: $provider (protocol: $protocol)"

    local key_var base_url api_key auth_token_var auth_token
    key_var="$(get_provider_value "PROVIDER_API_KEY_VARS" "$provider")"
    base_url="$(get_provider_value "PROVIDER_BASE_URLS" "$provider")"
    if [[ -n "$key_var" ]]; then
        api_key="$(get_var_value "$key_var")"
    else
        api_key=""
    fi

    # Get auth token for Anthropic protocol
    auth_token_var=""
    auth_token=""
    if [[ "$protocol" == "anthropic" ]]; then
        auth_token_var="$(get_provider_value "PROVIDER_AUTH_TOKENS" "$provider")"
        if [[ -n "$auth_token_var" ]]; then
            auth_token="$(get_var_value "$auth_token_var")"
        fi
    fi

    # Use auth_token as api_key fallback for anthropic protocol
    if [[ -z "$api_key" && -n "$auth_token" ]]; then
        api_key="$auth_token"
        key_var="$auth_token_var"
    fi

    # Check if API key is available
    if [[ -z "$api_key" ]]; then
        local missing_vars=""
        if [[ "$protocol" == "anthropic" ]]; then
            [[ -n "$key_var" ]] && missing_vars="$key_var"
            [[ -n "$auth_token_var" ]] && {
                [[ -n "$missing_vars" ]] && missing_vars="$missing_vars or "
                missing_vars="${missing_vars}${auth_token_var}"
            }
        else
            missing_vars="$key_var"
        fi
        echo "❌ $provider: API key not found (protocol: $protocol)"
        echo "💡 Set $missing_vars in your environment."
        echo
        return 1
    fi

    echo "✅ API key found: $(mask "$api_key")"
    echo
    echo "🔗 Base URL: $base_url"

    # Determine endpoint and auth headers based on protocol
    local test_endpoint auth_headers
    # Strip trailing slash from base_url if present
    base_url="${base_url%/}"

    if [[ "$protocol" == "anthropic" ]]; then
        # Anthropic uses x-api-key header
        # If base_url already ends with /v1, append /messages; otherwise append /v1/messages
        if [[ "$base_url" == */v1 ]]; then
            test_endpoint="${base_url}/messages"
        else
            test_endpoint="${base_url}/v1/messages"
        fi
        auth_headers=(-H "x-api-key: $api_key" -H "anthropic-version: 2023-06-01")
    else
        # OpenAI uses Authorization: Bearer header
        # Endpoint: base_url/models
        test_endpoint="${base_url}/models"
        auth_headers=(-H "Authorization: Bearer $api_key")
    fi

    echo "🌐 Testing connectivity to: $test_endpoint"

    local start_time
    start_time=$(date +%s.%N)
    local response

    # Use curl or wget to test API endpoint
    if command -v curl >/dev/null 2>&1; then
        response=$(curl -s -w "%{http_code}" -o /dev/null \
            --max-time 10 \
            "${auth_headers[@]}" \
            -H "Content-Type: application/json" \
            "$test_endpoint" 2>/dev/null)
    elif command -v wget >/dev/null 2>&1; then
        # Construct wget headers
        local wget_headers=()
        if [[ "$protocol" == "anthropic" ]]; then
            wget_headers+=("--header=x-api-key: $api_key" "--header=anthropic-version: 2023-06-01")
        else
            wget_headers+=("--header=Authorization: Bearer $api_key")
        fi
        wget_headers+=("--header=Content-Type: application/json")
        
        # wget prints server response headers to stderr with --server-response (-S)
        # We capture stderr, grep for HTTP status code
        local wget_out
        wget_out=$(wget -q -S -O /dev/null --timeout=10 "${wget_headers[@]}" "$test_endpoint" 2>&1)
        
        # Extract the last HTTP status code
        response=$(echo "$wget_out" | grep "HTTP/" | tail -1 | awk '{print $2}')
    else
        echo "❌ neither curl nor wget found. Please install one to test API connectivity."
        echo
        return 1
    fi

    local end_time
    end_time=$(date +%s.%N)
    local duration
    duration=$(echo "$end_time - $start_time" | bc 2>/dev/null || echo "N/A")

    case "$response" in
        200)
            echo "✅ $provider: Connected successfully (protocol: $protocol)"
            echo
            echo "⏱️ Response time: ${duration}s"
            ;;
        401)
            echo "❌ $provider: Authentication failed (protocol: $protocol)"
            echo "💡 Check your API key: $key_var"
            echo
            return 1
            ;;
        403)
            echo "❌ $provider: Access forbidden (protocol: $protocol)"
            echo "💡 Check API key permissions"
            echo
            return 1
            ;;
        404)
            echo "⚠️  $provider: Endpoint not found (protocol: $protocol, HTTP $response)"
            echo "💡 Provider may use different API path"
            echo
            ;;
        405)
            # For Anthropic, /v1/messages returns 405 for GET requests (it requires POST)
            # This still confirms the endpoint exists and auth headers are valid
            if [[ "$protocol" == "anthropic" ]]; then
                echo "✅ $provider: Connected successfully (protocol: $protocol)"
                echo "💡 Anthropic messages endpoint verified (requires POST for full test)"
                echo
                echo "⏱️ Response time: ${duration}s"
            else
                echo "⚠️  $provider: Method not allowed (protocol: $protocol, HTTP $response)"
                echo
            fi
            ;;
        429)
            echo "⚠️  $provider: Rate limited (protocol: $protocol)"
            echo "💡 Please try again later"
            echo
            return 1
            ;;
        "")
            echo "❌ $provider: Connection timeout or network error (protocol: $protocol)"
            echo "💡 Check internet connection and base URL"
            echo
            return 1
            ;;
        5*)
            echo "❌ $provider: Server error (protocol: $protocol, HTTP $response)"
            echo
            return 1
            ;;
        *)
            echo "⚠️  $provider: Unexpected response (protocol: $protocol, HTTP $response)"
            echo "💡 Provider may have different API format"
            echo
            ;;
    esac

    echo "🏁 Test completed for provider: $provider"
    echo
}

# --- Quickstart v2 helpers ---------------------------------------------------
#
# These pure-bash helpers parse the quickstart-{synthetic,alibaba}.json files
# in schema v2. They avoid jq to keep the project's zero-runtime-deps ethos.

# Extract a top-level JSON string scalar by key from a JSON document.
# Usage: _qs_json_string "$json" "schema_version"
# Echoes the value (without quotes), or empty string if not found.
_qs_json_string() {
    local json="$1" key="$2"
    # Look for "key": "value" anywhere in the doc. The first occurrence wins,
    # so callers should isolate sub-objects before calling on inner keys.
    printf '%s' "$json" \
        | tr -d '\n' \
        | grep -o "\"$key\"[[:space:]]*:[[:space:]]*\"[^\"]*\"" \
        | head -n 1 \
        | sed -E 's/^"[^"]*"[[:space:]]*:[[:space:]]*"//; s/"$//'
}

# Extract a single JSON object value by key from a top-level document.
# Echoes the object text including its surrounding braces.
# Returns empty if not found.
_qs_json_object() {
    local json="$1" key="$2"
    # Find the index of "key" in the document.
    local prefix rest depth=0 i ch out=""
    rest="${json#*\""$key"\"}"
    if [[ "$rest" == "$json" ]]; then
        # Key not present
        return 0
    fi
    # Skip past the colon to the opening brace.
    rest="${rest#*:}"
    # Strip leading whitespace.
    rest="${rest#"${rest%%[!$' \t\n\r']*}"}"
    if [[ "${rest:0:1}" != "{" ]]; then
        return 0
    fi
    # Walk the object respecting nested braces and strings.
    local in_string=false esc=false
    for (( i=0; i<${#rest}; i++ )); do
        ch="${rest:i:1}"
        out+="$ch"
        if [[ "$in_string" == true ]]; then
            if [[ "$esc" == true ]]; then
                esc=false
            elif [[ "$ch" == "\\" ]]; then
                esc=true
            elif [[ "$ch" == '"' ]]; then
                in_string=false
            fi
            continue
        fi
        case "$ch" in
            '"') in_string=true ;;
            '{') ((depth++)) ;;
            '}') ((depth--))
                if [[ $depth -eq 0 ]]; then
                    printf '%s' "$out"
                    return 0
                fi
                ;;
        esac
    done
    return 0
}

# Extract a JSON array body by key from a document.
# Echoes the contents *between* the [ and ], not including the brackets.
# Returns empty if not found.
_qs_json_array_body() {
    local json="$1" key="$2"
    local rest depth=0 i ch out="" in_string=false esc=false
    rest="${json#*\""$key"\"}"
    if [[ "$rest" == "$json" ]]; then
        return 0
    fi
    rest="${rest#*:}"
    rest="${rest#"${rest%%[!$' \t\n\r']*}"}"
    if [[ "${rest:0:1}" != "[" ]]; then
        return 0
    fi
    # Skip the opening [.
    rest="${rest:1}"
    for (( i=0; i<${#rest}; i++ )); do
        ch="${rest:i:1}"
        if [[ "$in_string" == true ]]; then
            out+="$ch"
            if [[ "$esc" == true ]]; then
                esc=false
            elif [[ "$ch" == "\\" ]]; then
                esc=true
            elif [[ "$ch" == '"' ]]; then
                in_string=false
            fi
            continue
        fi
        case "$ch" in
            '"') in_string=true; out+="$ch" ;;
            '[') ((depth++)); out+="$ch" ;;
            ']')
                if [[ $depth -eq 0 ]]; then
                    printf '%s' "$out"
                    return 0
                fi
                ((depth--)); out+="$ch"
                ;;
            *) out+="$ch" ;;
        esac
    done
    return 0
}

# Split an array body of objects into a NUL-delimited list of JSON objects.
# Each emitted object includes its surrounding braces. Use NUL because object
# bodies span multiple lines.
# Callers should consume with: while IFS= read -r -d '' obj; do ...; done < <(...)
_qs_split_object_array() {
    local body="$1"
    local depth=0 i ch out="" in_string=false esc=false started=false
    for (( i=0; i<${#body}; i++ )); do
        ch="${body:i:1}"
        if [[ "$in_string" == true ]]; then
            out+="$ch"
            if [[ "$esc" == true ]]; then
                esc=false
            elif [[ "$ch" == "\\" ]]; then
                esc=true
            elif [[ "$ch" == '"' ]]; then
                in_string=false
            fi
            continue
        fi
        case "$ch" in
            '"') in_string=true; out+="$ch" ;;
            '{')
                if [[ "$started" == false ]]; then
                    started=true; out=""
                fi
                ((depth++)); out+="$ch"
                ;;
            '}')
                ((depth--)); out+="$ch"
                if [[ $depth -eq 0 ]]; then
                    printf '%s\0' "$out"
                    out=""
                    started=false
                fi
                ;;
            *)
                if [[ "$started" == true ]]; then
                    out+="$ch"
                fi
                ;;
        esac
    done
}

# Extract simple "key": "value" pairs from a flat JSON object.
# Emits one "key=value" per line. Skips nested objects/arrays.
# Used for family_latest-style maps.
_qs_extract_string_pairs() {
    local obj="$1"
    # Strip outer braces.
    obj="${obj#\{}"
    obj="${obj%\}}"
    # Find all "key": "value" pairs.
    printf '%s' "$obj" \
        | tr -d '\n' \
        | grep -oE '"[^"]+"[[:space:]]*:[[:space:]]*"[^"]*"' \
        | sed -E 's/^"([^"]+)"[[:space:]]*:[[:space:]]*"([^"]*)"$/\1=\2/'
}

# Extract array of strings (e.g. protocols).
# Echoes one string per line.
_qs_extract_string_array() {
    local body="$1"
    printf '%s' "$body" \
        | tr -d '\n' \
        | grep -oE '"[^"]*"' \
        | sed -E 's/^"//; s/"$//'
}

# Validate that a model id is safe to use as an INI section name.
# Allowed: alphanumerics, dot, dash, underscore.
_qs_id_is_safe() {
    local id="$1"
    [[ -n "$id" && "$id" =~ ^[a-zA-Z0-9._-]+$ ]]
}

# Process a single quickstart v2 JSON file. Appends provider and group
# sections to the user config. Echoes informational messages to stdout.
# On schema/validation error, returns 1 and emits an error message.
#
# Args:
#   $1 = path to JSON file
#   $2 = path to user config file
# Updates the global array `_qs_added_names` with names of added sections.
_qs_added_names=()
_qs_process_v2_file() {
    local json_file="$1" user_config="$2"
    local json
    json="$(cat "$json_file")"
    if [[ -z "$json" ]]; then
        echo "❌ Quickstart file is empty: $json_file" >&2
        return 1
    fi

    local schema_version
    schema_version="$(_qs_json_string "$json" "schema_version")"
    if [[ "$schema_version" != "2" ]]; then
        if [[ -z "$schema_version" ]]; then
            echo "❌ Quickstart file is missing schema_version (or has malformed JSON): $json_file" >&2
            echo "   This file may be in legacy v1 format. Re-run install.sh to fetch v2 files." >&2
        else
            echo "❌ Unsupported schema_version '$schema_version' in $json_file (expected '2')." >&2
        fi
        return 1
    fi

    local vendor_short api_key_var signup_url endpoints_obj
    vendor_short="$(_qs_json_string "$json" "vendor_short")"
    api_key_var="$(_qs_json_string "$json" "api_key_var")"
    signup_url="$(_qs_json_string "$json" "signup_url")"
    endpoints_obj="$(_qs_json_object "$json" "endpoints")"

    if [[ -z "$vendor_short" || -z "$api_key_var" || -z "$endpoints_obj" ]]; then
        echo "❌ Quickstart file missing required top-level fields (vendor_short, api_key_var, endpoints): $json_file" >&2
        return 1
    fi
    if ! _qs_id_is_safe "$vendor_short"; then
        echo "❌ Quickstart file vendor_short '$vendor_short' contains characters unsafe for config sections: $json_file" >&2
        return 1
    fi
    if ! _qs_id_is_safe "$api_key_var"; then
        echo "❌ Quickstart file api_key_var '$api_key_var' contains characters unsafe for config: $json_file" >&2
        return 1
    fi

    local endpoint_openai endpoint_anthropic
    endpoint_openai="$(_qs_json_string "$endpoints_obj" "openai")"
    endpoint_anthropic="$(_qs_json_string "$endpoints_obj" "anthropic")"

    local models_body family_latest_obj
    models_body="$(_qs_json_array_body "$json" "models")"
    family_latest_obj="$(_qs_json_object "$json" "family_latest")"

    # Map model id -> "openai,anthropic" of available protocols, used to
    # decide whether family_latest entries get groups vs single-member aliases.
    local -a model_ids=()
    local -a model_protocols=()  # parallel array, "openai,anthropic" form

    # Parse models[] block by block. Objects are NUL-delimited to survive
    # multi-line content.
    local model_obj id family version description upstream_id protocols_body
    while IFS= read -r -d '' model_obj; do
        [[ -z "$model_obj" ]] && continue
        id="$(_qs_json_string "$model_obj" "id")"
        family="$(_qs_json_string "$model_obj" "family")"
        version="$(_qs_json_string "$model_obj" "version")"
        description="$(_qs_json_string "$model_obj" "description")"
        upstream_id="$(_qs_json_string "$model_obj" "upstream_id")"
        protocols_body="$(_qs_json_array_body "$model_obj" "protocols")"

        if [[ -z "$id" ]]; then
            echo "  ⚠️  Skipping model with no id" >&2
            continue
        fi
        if ! _qs_id_is_safe "$id"; then
            echo "  ⚠️  Skipping model '$id' - id contains characters unsafe for config sections" >&2
            continue
        fi

        # Compute available protocols intersecting model.protocols with what
        # the file's endpoints declare.
        local proto have_openai=false have_anthropic=false
        while IFS= read -r proto; do
            [[ -z "$proto" ]] && continue
            case "$proto" in
                openai)    [[ -n "$endpoint_openai" ]]    && have_openai=true ;;
                anthropic) [[ -n "$endpoint_anthropic" ]] && have_anthropic=true ;;
            esac
        done < <(_qs_extract_string_array "$protocols_body")

        # Track for family_latest emission.
        local proto_csv=""
        [[ "$have_openai"    == true ]] && proto_csv="openai"
        if [[ "$have_anthropic" == true ]]; then
            [[ -n "$proto_csv" ]] && proto_csv+=","
            proto_csv+="anthropic"
        fi
        model_ids+=("$id")
        model_protocols+=("$proto_csv")

        local default_model="${upstream_id:-$id}"

        if [[ "$have_openai" == true ]]; then
            local pname="openai_${vendor_short}_${id}"
            _qs_emit_provider "$user_config" "$pname" "$endpoint_openai" \
                "$api_key_var" "$default_model" "$description" "openai" "$signup_url"
        fi
        if [[ "$have_anthropic" == true ]]; then
            local pname="anth_${vendor_short}_${id}"
            _qs_emit_provider "$user_config" "$pname" "$endpoint_anthropic" \
                "$api_key_var" "$default_model" "$description" "anthropic" "$signup_url"
        fi

        # Per-model group only when both protocols available.
        if [[ "$have_openai" == true && "$have_anthropic" == true ]]; then
            _qs_emit_group "$user_config" \
                "${vendor_short}_${id}" \
                "openai_${vendor_short}_${id},anth_${vendor_short}_${id}"
        fi
    done < <(_qs_split_object_array "$models_body")

    # Family-latest groups.
    if [[ -n "$family_latest_obj" ]]; then
        local pair fam fam_id idx j providers_csv
        while IFS= read -r pair; do
            [[ -z "$pair" ]] && continue
            fam="${pair%%=*}"
            fam_id="${pair#*=}"
            if ! _qs_id_is_safe "$fam"; then
                echo "  ⚠️  Skipping family_latest entry '$fam' - unsafe family name" >&2
                continue
            fi
            if ! _qs_id_is_safe "$fam_id"; then
                continue
            fi
            # Look up protocols for this model id from the parallel arrays.
            idx=-1
            for j in "${!model_ids[@]}"; do
                if [[ "${model_ids[$j]}" == "$fam_id" ]]; then
                    idx="$j"; break
                fi
            done
            if [[ "$idx" -lt 0 ]]; then
                echo "  ⚠️  family_latest references unknown model id '$fam_id'" >&2
                continue
            fi
            providers_csv=""
            case "${model_protocols[$idx]}" in
                "openai,anthropic")
                    providers_csv="openai_${vendor_short}_${fam_id},anth_${vendor_short}_${fam_id}" ;;
                "openai")
                    providers_csv="openai_${vendor_short}_${fam_id}" ;;
                "anthropic")
                    providers_csv="anth_${vendor_short}_${fam_id}" ;;
            esac
            [[ -z "$providers_csv" ]] && continue
            _qs_emit_group "$user_config" "${vendor_short}_${fam}" "$providers_csv"
        done < <(_qs_extract_string_pairs "$family_latest_obj")
    fi

    return 0
}

# Append a provider section to the user config if not already present.
_qs_emit_provider() {
    local user_config="$1" name="$2" base_url="$3" api_key_var="$4"
    local default_model="$5" description="$6" protocol="$7" signup_url="$8"

    if grep -q "^\[$name\]$" "$user_config" 2>/dev/null; then
        echo "  ⚠️  Skipping provider '$name' - already exists in config"
        return 0
    fi
    echo "  ➕ Adding provider: $name"
    {
        echo ""
        [[ -n "$description" ]] && echo "# $description"
        echo "[$name]"
        echo "base_url=$base_url"
        echo "api_key_var=$api_key_var"
        echo "default_model=$default_model"
        if [[ -n "$protocol" && "$protocol" != "openai" ]]; then
            echo "protocol=$protocol"
        fi
        [[ -n "$description" ]] && echo "description=$description"
        echo "enabled=true"
        if [[ -n "$signup_url" ]]; then
            echo "signup_url=$signup_url"
        fi
        echo ""
    } >> "$user_config"
    _qs_added_names+=("$name")
}

# Append a [group:NAME] section to the user config if not already present.
_qs_emit_group() {
    local user_config="$1" group_name="$2" providers_csv="$3"
    if grep -q "^\[group:$group_name\]$" "$user_config" 2>/dev/null; then
        echo "  ⚠️  Skipping group '$group_name' - already exists in config"
        return 0
    fi
    echo "  ➕ Adding group: $group_name"
    {
        echo ""
        echo "[group:$group_name]"
        echo "providers=$providers_csv"
        echo ""
    } >> "$user_config"
    _qs_added_names+=("group:$group_name")
}

# Resolve the user's selection of catalog sources for cmd_quickstart.
# Inputs:
#   $1 = positional argument from CLI (may be empty, "all", "synthetic",
#        "alibaba", or a comma-separated list).
#   $2 = comma-separated list of *available* sources (those whose JSON
#        files were found, in order: synthetic,alibaba).
# Output (echoed): a comma-separated subset of the available sources.
# Return code: 0 on valid selection, non-zero on invalid input. Caller
# uses the return code to decide whether to abort.
_qs_resolve_selection() {
    local arg="${1:-}"
    local available="${2:-}"

    # Normalize: trim whitespace around commas, lowercase.
    arg="$(printf '%s' "$arg" | tr '[:upper:]' '[:lower:]' | sed 's/[[:space:]]*,[[:space:]]*/,/g; s/^[[:space:]]*//; s/[[:space:]]*$//')"

    # Empty arg → caller decides (interactive prompt or "all" fallback).
    if [[ -z "$arg" ]]; then
        printf '%s' "$available"
        return 0
    fi

    if [[ "$arg" == "all" ]]; then
        printf '%s' "$available"
        return 0
    fi

    # Validate every comma-separated token is a known source AND is
    # currently available. Build the result preserving caller's order.
    local IFS=','
    local -a tokens
    read -r -a tokens <<< "$arg"
    local out=""
    local tok
    for tok in "${tokens[@]}"; do
        if [[ "$tok" != "synthetic" && "$tok" != "alibaba" ]]; then
            echo "❌ Unknown quickstart source: '$tok'. Valid: synthetic, alibaba, all (or comma-separated combinations)." >&2
            return 1
        fi
        # Must be in available list.
        if [[ ",$available," != *",$tok,"* ]]; then
            echo "❌ Quickstart source '$tok' selected but its JSON file is not available." >&2
            return 1
        fi
        if [[ -n "$out" ]]; then
            out+=","
        fi
        out+="$tok"
    done
    printf '%s' "$out"
    return 0
}

# Returns true when stdin is a TTY (interactive shell). Centralized so
# tests can stub it via function override.
_qs_is_interactive() {
    [[ -t 0 ]]
}

# Detect the user's shell rc file. Echoes the path, or empty for shells
# we don't auto-write to. Mirrors install.sh:307–315.
#
# bash → ~/.bashrc, falling back to ~/.bash_profile if .bashrc is
# missing AND .bash_profile exists. ~/.bashrc otherwise (created on
# write).
# zsh → ~/.zshrc.
# fish/csh/tcsh/other → empty (caller prints the export line manually).
_qs_detect_shell_rc() {
    local current_shell="${SHELL:-/bin/bash}"
    case "$current_shell" in
        */zsh)
            printf '%s' "$HOME/.zshrc"
            ;;
        */bash)
            if [[ ! -f "$HOME/.bashrc" && -f "$HOME/.bash_profile" ]]; then
                printf '%s' "$HOME/.bash_profile"
            else
                printf '%s' "$HOME/.bashrc"
            fi
            ;;
        *)
            # fish, csh, tcsh, sh, or anything unrecognized.
            printf ''
            ;;
    esac
}

# True (return 0) when the named env var is already set in the current
# environment, OR when the rc file contains an `export VAR=...` line
# (any leading whitespace, any quoting).
#
# Args: $1 = var name, $2 = rc file path (may be empty).
_qs_key_already_set() {
    local var="$1" rc_file="$2"
    [[ -z "$var" ]] && return 1
    # Env check.
    if [[ -n "${!var:-}" ]]; then
        return 0
    fi
    # rc-file check.
    if [[ -n "$rc_file" && -f "$rc_file" ]]; then
        if grep -qE "^[[:space:]]*export[[:space:]]+${var}=" "$rc_file"; then
            return 0
        fi
    fi
    return 1
}

# Prompt for an API key, masked. Treats empty input, 's', or
# whitespace-only as skip. On a real key, echoes the (trimmed) key on
# stdout and returns 0. On skip, returns 1.
#
# Args: $1 = var name (only used in the prompt label).
_qs_prompt_api_key() {
    local var="$1"
    local key=""
    # -s: don't echo input. -r: don't process backslashes. -p prompt
    # writes to stderr to keep stdout clean for the caller.
    printf '   Paste your %s (input hidden, blank or '\''s'\'' to skip): ' "$var" >&2
    IFS= read -r -s key
    printf '\n' >&2
    # Trim whitespace.
    local trimmed
    trimmed="$(printf '%s' "$key" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')"
    if [[ -z "$trimmed" || "$trimmed" == "s" || "$trimmed" == "S" ]]; then
        return 1
    fi
    printf '%s' "$trimmed"
    return 0
}

# Append `export VAR='value'` to the given rc file. Idempotent: if a
# matching `export VAR=` line already exists, leaves the file alone
# and returns 1 (caller knows nothing was written).
#
# Args: $1 = var, $2 = value, $3 = rc file path (must be non-empty).
# Single-quote escaping uses the standard close-escape-reopen pattern
# so values containing apostrophes round-trip correctly.
_qs_append_export_to_rc() {
    local var="$1" value="$2" rc_file="$3"
    if [[ -z "$rc_file" ]]; then
        return 1
    fi
    # Don't duplicate.
    if [[ -f "$rc_file" ]] && grep -qE "^[[:space:]]*export[[:space:]]+${var}=" "$rc_file"; then
        return 1
    fi
    # Ensure the file exists and ends with a newline before appending.
    if [[ ! -f "$rc_file" ]]; then
        : > "$rc_file" || return 1
    elif [[ -s "$rc_file" ]]; then
        # If file is non-empty and lacks trailing newline, add one.
        local last
        last=$(tail -c 1 "$rc_file" 2>/dev/null || true)
        if [[ "$last" != $'\n' ]]; then
            printf '\n' >> "$rc_file" || return 1
        fi
    fi
    # Single-quote-escape the value: every ' becomes '"'"'.
    local escaped="${value//\'/\'\"\'\"\'}"
    printf "export %s='%s'\n" "$var" "$escaped" >> "$rc_file" || return 1
    return 0
}

# Run cmd_test against a provider, capture its output, and print a
# single-line ✅/❌ summary. Always returns 0 — verification is
# informational and must not abort quickstart.
#
# Args: $1 = provider name to test.
_qs_verify_key() {
    local provider="$1"
    local out rc
    out="$(cmd_test "$provider" 2>&1)"
    rc=$?
    if [[ $rc -eq 0 ]]; then
        echo "   ✅ Verified: $provider"
    else
        # Print warning but never propagate failure to caller.
        echo "   ⚠️  Warning: verification of $provider failed (exit $rc). Set the key manually if needed."
        # Also surface the last line of the cmd_test output for context.
        local tail_line
        tail_line="$(printf '%s' "$out" | tail -n 1)"
        [[ -n "$tail_line" ]] && echo "      $tail_line"
    fi
    return 0
}

cmd_quickstart() {
    echo "🚀 Quickstart - Adding provider definitions from quickstart JSON files"
    echo

    # Locate quickstart JSON files. LLM_ENV_QUICKSTART_DIR overrides the
    # script directory (used by tests and advanced setups).
    local quickstart_dir="${LLM_ENV_QUICKSTART_DIR:-$(get_script_dir)}"
    local synthetic_json="$quickstart_dir/quickstart-synthetic.json"
    local alibaba_json="$quickstart_dir/quickstart-alibaba.json"

    # Track which sources are available (in deterministic order).
    local available=""
    [[ -f "$synthetic_json" ]] && available="${available:+$available,}synthetic"
    [[ -f "$alibaba_json" ]] && available="${available:+$available,}alibaba"

    if [[ -z "$available" ]]; then
        echo "❌ No quickstart JSON files found in: $quickstart_dir" >&2
        echo "💡 Expected: quickstart-synthetic.json and/or quickstart-alibaba.json" >&2
        return 1
    fi

    # Resolve which sources to process. Empty arg + non-TTY → all available.
    # Empty arg + TTY → currently still all (interactive prompt arrives in
    # Phase 2 of the interactive-quickstart feature).
    local selection
    if ! selection="$(_qs_resolve_selection "${1:-}" "$available")"; then
        return 1
    fi

    if [[ -z "$selection" ]]; then
        echo "ℹ️  No sources selected — exiting."
        return 0
    fi

    local user_config
    user_config="$(get_user_config_path)"
    mkdir -p "$(dirname "$user_config")"
    if [[ ! -f "$user_config" ]]; then
        echo "📝 Creating user configuration file: $user_config"
        touch "$user_config"
    else
        echo "📝 Using existing user configuration: $user_config"
    fi

    # Detect shell rc once up-front (empty for unsupported shells).
    local rc_file
    rc_file="$(_qs_detect_shell_rc)"

    _qs_added_names=()
    local rc=0
    local interactive=false
    if _qs_is_interactive; then
        interactive=true
    fi

    local src
    local IFS_old="$IFS"
    IFS=','
    for src in $selection; do
        IFS="$IFS_old"
        local json_file="" api_key_var="" signup_url="" verify_provider=""
        case "$src" in
            synthetic)
                json_file="$synthetic_json"
                api_key_var="LLM_SYNTHETIC_API_KEY"
                signup_url="https://synthetic.new/?referral=ugceNlJ08A3Eeww"
                verify_provider="anth_synth_kimi-k2.5"
                ;;
            alibaba)
                json_file="$alibaba_json"
                api_key_var="LLM_ALIBABA_API_KEY"
                signup_url="https://www.alibabacloud.com/campaign/benefits?referral_code=A92LUX"
                verify_provider="anth_alibaba_kimi-k2.5"
                ;;
        esac

        echo "🔍 Processing: $json_file"
        if ! _qs_process_v2_file "$json_file" "$user_config"; then
            rc=1
            IFS=','
            continue
        fi
        echo

        if [[ "$interactive" == true ]]; then
            if _qs_key_already_set "$api_key_var" "$rc_file"; then
                echo "✅ $api_key_var is already configured — skipping prompt."
                echo
            else
                echo "🔑 Sign up for $src to get your API key:"
                printf '   %s\n' "$(link "$signup_url" "$signup_url")"
                echo
                printf '   Press Enter once you have your key (or '\''s'\'' + Enter to skip): '
                read -r _   # discard; just a pause
                local key
                if key="$(_qs_prompt_api_key "$api_key_var")"; then
                    if [[ -n "$rc_file" ]]; then
                        if _qs_append_export_to_rc "$api_key_var" "$key" "$rc_file"; then
                            echo "   ✓ Appended $api_key_var to $rc_file"
                        else
                            # rc_file write failed or duplicate — print fallback.
                            echo "   ⚠️  Could not write to $rc_file. Add this line manually:"
                            echo "      export $api_key_var='<your key>'"
                        fi
                    else
                        echo "   ℹ️  Your shell isn't auto-supported. Add this to your shell config:"
                        echo "      export $api_key_var='<your key>'"
                    fi
                    # Make the key visible to cmd_test in this session for verification.
                    export "$api_key_var=$key"
                    _qs_verify_key "$verify_provider"
                else
                    echo "   ⏭️  Skipped — set $api_key_var manually when you're ready."
                fi
                echo
            fi
        fi
        IFS=','
    done
    IFS="$IFS_old"

    if [[ ${#_qs_added_names[@]} -gt 0 ]]; then
        echo "🎉 Added ${#_qs_added_names[@]} new entr$([[ ${#_qs_added_names[@]} -eq 1 ]] && echo y || echo ies) to your configuration."
    else
        echo "ℹ️  No new providers or groups were added (they may already exist)."
    fi

    if [[ "$interactive" != true ]]; then
        # Non-interactive path: print signup links footer for the user
        # to follow up on manually.
        echo
        echo "🔗 Sign up for API access:"
        printf '   Synthetic: %s\n' "$(link "https://synthetic.new/?referral=ugceNlJ08A3Eeww" "https://synthetic.new")"
        printf '   Alibaba Cloud Coding Plan: %s\n' "$(link "https://www.alibabacloud.com/campaign/benefits?referral_code=A92LUX" "https://alibabacloud.com/campaign/benefits")"
    fi

    echo
    echo "💡 Next steps:"
    echo "   llm-env list                       # see what's available"
    echo "   llm-env set anth_synth_kimi-k2.5   # activate a provider"
    if [[ "$interactive" == true && -n "$rc_file" ]]; then
        echo "   source $rc_file                    # reload shell so new keys are active"
    fi
    echo

    return $rc
}

