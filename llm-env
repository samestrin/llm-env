cmd_config_edit() {
    local user_config
    user_config="$(get_user_config_path)"
    
    if [[ ! -f "${user_config}" ]]; then
        echo "⚠️  User configuration not found. Creating it first..."
        echo
        cmd_config_init || return 1
    fi
    
    # Use user's preferred editor
    local editor="${EDITOR:-${VISUAL:-nano}}"
    "$editor" "$user_config"
    
    echo "💡 Run 'source llm-env config validate' to check your configuration"
    echo
}

cmd_config_add() {
    local provider="$1"
    if [[ -z "$provider" ]]; then
        echo "Usage: source llm-env config add <provider_name>"
        return 1
    fi
    
    # Validate provider name format
    if ! validate_provider_name "$provider"; then
        return 1
    fi
    
    echo "Adding new provider: $provider"
    echo "Please provide the following information:"
    
    # Set timeout for read operations
    local TMOUT=30
    read -r -t $TMOUT -p "Base URL: " base_url || { echo "Timeout reached"; return 1; }
    read -r -t $TMOUT -p "API Key Environment Variable: " api_key_var || { echo "Timeout reached"; return 1; }
    read -r -t $TMOUT -p "Default Model: " default_model || { echo "Timeout reached"; return 1; }
    read -r -t $TMOUT -p "Description (optional): " description || { echo "Timeout reached"; return 1; }
    
    # Sanitize input values
    base_url=$(sanitize_config_value "$base_url")
    api_key_var=$(sanitize_config_value "$api_key_var")
    default_model=$(sanitize_config_value "$default_model")
    description=$(sanitize_config_value "$description")
    
    local user_config
    user_config="$(get_user_config_path)"
    
    # Create user config if it doesn't exist
    if [[ ! -f "$user_config" ]]; then
        cmd_config_init || return 1
    fi
    
    # Append new provider
    {
        echo ""
        echo "[$provider]"
        echo "base_url=$base_url"
        echo "api_key_var=$api_key_var"
        echo "default_model=$default_model"
        [[ -n "$description" ]] && echo "description=$description"
        echo "enabled=true"
    } >> "$user_config"
    
    echo "✅ Added provider '$provider' to $user_config"
    echo "💡 Don't forget to set $api_key_var in your shell profile"
}

cmd_config_remove() {
    local provider="$1"
    if [[ -z "$provider" ]]; then
        echo "Usage: source llm-env config remove <provider_name>"
        return 1
    fi
    
    # Validate provider name format
    if ! validate_provider_name "$provider"; then
        return 1
    fi
    
    local user_config
    user_config="$(get_user_config_path)"
    
    if [[ ! -f "$user_config" ]]; then
        echo "❌ User configuration not found: $user_config"
        return 1
    fi
    
    # Create backup
    cp "$user_config" "$user_config.backup"
    
    # Remove provider section
    awk -v provider="$provider" '
        BEGIN { in_section = 0 }
        /^\[/ { 
            if ($0 == "[" provider "]") {
                in_section = 1
                next
            } else {
                in_section = 0
            }
        }
        !in_section { print }
    ' "$user_config.backup" > "$user_config"
    
    echo "✅ Removed provider '$provider' from $user_config"
    echo "💡 Backup saved as $user_config.backup"
}

cmd_test() {
    local provider="$1"
    if [[ -z "$provider" ]]; then
        echo "Usage: source llm-env test <provider>"
        echo "Available providers: ${AVAILABLE_PROVIDERS[*]}"
        return 1
    fi

    # Validate provider name format
    if ! validate_provider_name "$provider"; then
        return 1
    fi

    # Validate provider
    validate_provider "$provider"
    local validate_result=$?
    if [[ $validate_result -ne 0 ]]; then
        case $validate_result in
            1) echo "❌ Unknown provider: $provider" ;;
            2) echo "❌ Provider disabled: $provider" ;;
        esac
        echo "Available providers: ${AVAILABLE_PROVIDERS[*]}"
        return 1
    fi

    # Get protocol for this provider (defaults to "openai")
    local protocol
    get_provider_value "PROVIDER_PROTOCOLS" "$provider"; protocol="${REPLY:-openai}"

    echo "🧪 Testing provider: $provider (protocol: $protocol)"

    local key_var base_url api_key
    get_provider_value "PROVIDER_API_KEY_VARS" "$provider"; key_var="$REPLY"
    get_provider_value "PROVIDER_BASE_URLS" "$provider"; base_url="$REPLY"
    get_var_value "$key_var"; api_key="$REPLY"

    # Check if API key is available
    if [[ -z "$api_key" ]]; then
        echo "❌ $provider: API key not found (protocol: $protocol)"
        echo "💡 Set $key_var in your environment."
        echo
        return 1
    fi

    echo "✅ API key found: $(mask "$api_key")"
    echo
    echo "🔗 Base URL: $base_url"

    # Determine endpoint and auth headers based on protocol
    local test_endpoint auth_headers
    # Strip trailing slash from base_url if present
    base_url="${base_url%/}"

    if [[ "$protocol" == "anthropic" ]]; then
        # Anthropic uses x-api-key header
        # Endpoint: base_url/messages (base_url typically includes /v1)
        test_endpoint="${base_url}/messages"
        auth_headers=(-H "x-api-key: $api_key" -H "anthropic-version: 2023-06-01")
    else
        # OpenAI uses Authorization: Bearer header
        # Endpoint: base_url/models
        test_endpoint="${base_url}/models"
        auth_headers=(-H "Authorization: Bearer $api_key")
    fi

    echo "🌐 Testing connectivity to: $test_endpoint"

    local start_time
    start_time=$(date +%s.%N)
    local response

    # Use curl or wget to test API endpoint
    if command -v curl >/dev/null 2>&1; then
        response=$(curl -s -w "%{http_code}" -o /dev/null \
            --max-time 10 \
            "${auth_headers[@]}" \
            -H "Content-Type: application/json" \
            "$test_endpoint" 2>/dev/null)
    elif command -v wget >/dev/null 2>&1; then
        # Construct wget headers
        local wget_headers=()
        if [[ "$protocol" == "anthropic" ]]; then
            wget_headers+=("--header=x-api-key: $api_key" "--header=anthropic-version: 2023-06-01")
        else
            wget_headers+=("--header=Authorization: Bearer $api_key")
        fi
        wget_headers+=("--header=Content-Type: application/json")
        
        # wget prints server response headers to stderr with --server-response (-S)
        # We capture stderr, grep for HTTP status code
        local wget_out
        wget_out=$(wget -q -S -O /dev/null --timeout=10 "${wget_headers[@]}" "$test_endpoint" 2>&1)
        
        # Extract the last HTTP status code
        response=$(echo "$wget_out" | grep "HTTP/" | tail -1 | awk '{print $2}')
    else
        echo "❌ neither curl nor wget found. Please install one to test API connectivity."
        echo
        return 1
    fi

    local end_time
    end_time=$(date +%s.%N)
    local duration
    duration=$(echo "$end_time - $start_time" | bc 2>/dev/null || echo "N/A")

    case "$response" in
        200)
            echo "✅ $provider: Connected successfully (protocol: $protocol)"
            echo
            echo "⏱️ Response time: ${duration}s"
            ;;
        401)
            echo "❌ $provider: Authentication failed (protocol: $protocol)"
            echo "💡 Check your API key: $key_var"
            echo
            return 1
            ;;
        403)
            echo "❌ $provider: Access forbidden (protocol: $protocol)"
            echo "💡 Check API key permissions"
            echo
            return 1
            ;;
        404)
            echo "⚠️  $provider: Endpoint not found (protocol: $protocol, HTTP $response)"
            echo "💡 Provider may use different API path"
            echo
            ;;
        405)
            # For Anthropic, /v1/messages returns 405 for GET requests (it requires POST)
            # This still confirms the endpoint exists and auth headers are valid
            if [[ "$protocol" == "anthropic" ]]; then
                echo "✅ $provider: Connected successfully (protocol: $protocol)"
                echo "💡 Anthropic messages endpoint verified (requires POST for full test)"
                echo
                echo "⏱️ Response time: ${duration}s"
            else
                echo "⚠️  $provider: Method not allowed (protocol: $protocol, HTTP $response)"
                echo
            fi
            ;;
        429)
            echo "⚠️  $provider: Rate limited (protocol: $protocol)"
            echo "💡 Please try again later"
            echo
            return 1
            ;;
        "")
            echo "❌ $provider: Connection timeout or network error (protocol: $protocol)"
            echo "💡 Check internet connection and base URL"
            echo
            return 1
            ;;
        5*)
            echo "❌ $provider: Server error (protocol: $protocol, HTTP $response)"
            echo
            return 1
            ;;
        *)
            echo "⚠️  $provider: Unexpected response (protocol: $protocol, HTTP $response)"
            echo "💡 Provider may have different API format"
            echo
            ;;
    esac

    echo "🏁 Test completed for provider: $provider"
    echo
}

cmd_quickstart() {
    echo "🚀 Quickstart - Adding synthetic model providers"
    echo

    # Check for quickstart JSON files in the same directory
    local script_dir
    script_dir="$(get_script_dir)"
    local synthetic_json="$script_dir/quickstart-synthetic.json"
    local alibaba_json="$script_dir/quickstart-alibaba.json"

    local json_files=()
    if [[ -f "$synthetic_json" ]]; then
        json_files+=("$synthetic_json")
    fi
    if [[ -f "$alibaba_json" ]]; then
        json_files+=("$alibaba_json")
    fi

    if [[ ${#json_files[@]} -eq 0 ]]; then
        echo "❌ No quickstart JSON files found in script directory: $script_dir"
        echo "💡 Expected files: quickstart-synthetic.json, quickstart-alibaba.json"
        return 1
    fi

    # Load configuration from user config path
    local user_config
    user_config="$(get_user_config_path)"

    # Create directory if it doesn't exist
    mkdir -p "$(dirname "$user_config")"

    # Check if config file exists, create if it doesn't
    if [[ ! -f "$user_config" ]]; then
        echo "📝 Creating user configuration file: $user_config"
        touch "$user_config"
    else
        echo "📝 Using existing user configuration: $user_config"
    fi

    # Process each JSON file
    local added_providers=()
    for json_file in "${json_files[@]}"; do
        echo "🔍 Processing: $json_file"

        # Parse the JSON file and extract providers
        local provider_start_found=false
        local in_providers_array=false
        local provider_block=""
        local current_line=""
        local brace_level=0
        local in_provider_block=false

        while IFS= read -r line || [[ -n "$line" ]]; do
            # Remove leading/trailing whitespace and commas
            local clean_line
            clean_line="$(echo "$line" | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*,[[:space:]]*$//' | sed 's/[[:space:]]*$//')"

            # Check if we're in the providers array
            if [[ "$clean_line" == '"providers"'* ]] || [[ "$clean_line" == "'providers'"* ]]; then
                in_providers_array=true
                # Handle "providers": [ on same line
                if [[ "$clean_line" == *"["* ]]; then
                    brace_level=1
                fi
                continue
            fi

            # Start counting braces to find individual provider objects
            if [[ "$in_providers_array" == true ]] && [[ "$clean_line" == "["* ]]; then
                brace_level=1
                continue
            fi

            # Process braces to track object boundaries
            if [[ "$in_providers_array" == true ]] && [[ "$brace_level" -gt 0 ]]; then
                local open_braces close_braces
                open_braces=$(echo "$clean_line" | grep -o '{' | wc -l)
                close_braces=$(echo "$clean_line" | grep -o '}' | wc -l)

                if [[ "$open_braces" -gt 0 ]]; then
                    # Start a new provider block if not already in one
                    if [[ "$brace_level" -eq 1 ]] && [[ "$in_provider_block" == false ]]; then
                        in_provider_block=true
                        provider_block="{"
                        current_line=""
                    else
                        # Add to current block
                        if [[ "$in_provider_block" == true ]]; then
                            provider_block="$provider_block$clean_line"$'\n'
                        fi
                    fi
                    ((brace_level += open_braces))
                fi

                if [[ "$close_braces" -gt 0 ]]; then
                    ((brace_level -= close_braces))

                    if [[ "$in_provider_block" == true ]]; then
                        provider_block="$provider_block$clean_line"$'\n'

                        # If we've closed the provider object (back to array level)
                        if [[ "$brace_level" -le 1 ]]; then

                            # Extract provider fields from the block
                            local name base_url api_key_var default_model description protocol enabled
                            name=$(echo "$provider_block" | grep -o '"name":[[:space:]]*"[^"]*"' | head -1 | sed 's/"name":[[:space:]]*"//' | sed 's/"$//' | sed 's/[",]//g')
                            base_url=$(echo "$provider_block" | grep -o '"base_url":[[:space:]]*"[^"]*"' | head -1 | sed 's/"base_url":[[:space:]]*"//' | sed 's/"$//' | sed 's/[",]//g')
                            api_key_var=$(echo "$provider_block" | grep -o '"api_key_var":[[:space:]]*"[^"]*"' | head -1 | sed 's/"api_key_var":[[:space:]]*"//' | sed 's/"$//' | sed 's/[",]//g')
                            default_model=$(echo "$provider_block" | grep -o '"default_model":[[:space:]]*"[^"]*"' | head -1 | sed 's/"default_model":[[:space:]]*"//' | sed 's/"$//' | sed 's/[",]//g')

                            # Handle special case where default_model might need adjustment
                            # If model has format like "hf:Vendor/ModelName", use just the model name part
                            if [[ "$default_model" == hf:*/* ]]; then
                                # Extract just the model name part after the last "/"
                                default_model="${default_model##*/}"
                            fi
                            description=$(echo "$provider_block" | grep -o '"description":[[:space:]]*"[^"]*"' | head -1 | sed 's/"description":[[:space:]]*"//' | sed 's/"$//' | sed 's/[",]//g')
                            protocol=$(echo "$provider_block" | grep -o '"protocol":[[:space:]]*"[^"]*"' | head -1 | sed 's/"protocol":[[:space:]]*"//' | sed 's/"$//' | sed 's/[",]//g' | sed 's/^$/openai/')
                            enabled=$(echo "$provider_block" | grep -o '"enabled":[[:space:]]*[a-zA-Z]*' | head -1 | sed 's/"enabled":[[:space:]]*//' | sed 's/[",]//g' | sed 's/^$/true/')
                            local signup_url
                            signup_url=$(echo "$provider_block" | grep -o '"signup_url":[[:space:]]*"[^"]*"' | head -1 | sed 's/"signup_url":[[:space:]]*"//' | sed 's/"$//' | sed 's/[",]//g')

                            # Write provider to user config if not already present
                            if [[ -n "$name" ]] && [[ -n "$base_url" ]] && [[ -n "$api_key_var" ]]; then
                                # Check if provider already exists in config
                                if ! grep -q "^\[$name\]$" "$user_config" 2>/dev/null; then
                                    echo "  ➕ Adding provider: $name"

                                    {
                                        echo ""
                                        echo "# $description"
                                        echo "[$name]"
                                        echo "base_url=$base_url"
                                        echo "api_key_var=$api_key_var"
                                        echo "default_model=$default_model"
                                        if [[ -n "$protocol" ]] && [[ "$protocol" != "openai" ]]; then
                                            echo "protocol=$protocol"
                                        fi
                                        echo "description=$description"
                                        echo "enabled=$enabled"
                                        if [[ -n "$signup_url" ]]; then
                                            echo "signup_url=$signup_url"
                                        fi
                                        echo ""
                                    } >> "$user_config"

                                    added_providers+=("$name")
                                else
                                    echo "  ⚠️  Skipping provider '$name' - already exists in config"
                                fi
                            fi

                            # Reset for next provider
                            provider_block=""
                            in_provider_block=false
                        else
                            # Still in provider block, add the line
                            provider_block="$provider_block$clean_line"$'\n'
                        fi
                    fi
                elif [[ "$in_provider_block" == true ]]; then
                    # Inside provider block, add the line
                    provider_block="$provider_block$clean_line"$'\n'
                fi
            fi
        done < "$json_file"

        echo
    done

    if [[ ${#added_providers[@]} -gt 0 ]]; then
        echo "🎉 Successfully added ${#added_providers[@]} new provider(s) to your configuration:"
        for provider in "${added_providers[@]}"; do
            echo "  - $provider"
        done
        echo
        echo "💡 Next steps:"
        echo "   1. Get your API keys:"
        local shown_keys=""
        for provider in "${added_providers[@]}"; do
            local api_key_var signup_url
            api_key_var=$(grep -A 10 "^\[$provider\]$" "$user_config" | grep "^api_key_var=" | cut -d'=' -f2)
            signup_url=$(grep -A 10 "^\[$provider\]$" "$user_config" | grep "^signup_url=" | cut -d'=' -f2-)
            # Only show each unique key var once
            if [[ "$shown_keys" != *"|$api_key_var|"* ]]; then
                if [[ -n "$signup_url" ]]; then
                    printf '      🔑 %s → Sign up: %s\n' "$api_key_var" "$(link "$signup_url" "$signup_url")"
                else
                    echo "      🔑 $api_key_var"
                fi
                shown_keys="${shown_keys}|$api_key_var|"
            fi
        done
        echo
        echo "   2. Add your keys to your shell profile:"
        shown_keys=""
        for provider in "${added_providers[@]}"; do
            local api_key_var
            api_key_var=$(grep -A 10 "^\[$provider\]$" "$user_config" | grep "^api_key_var=" | cut -d'=' -f2)
            if [[ "$shown_keys" != *"|$api_key_var|"* ]]; then
                echo "      export $api_key_var='your-key-here'"
                shown_keys="${shown_keys}|$api_key_var|"
            fi
        done
        echo "   3. Reload your shell: source ~/.bashrc or source ~/.zshrc"
        echo "   4. Test the new providers: source llm-env test <provider-name>"
        echo "   5. Use a provider: source llm-env set <provider-name>"
    else
        echo "ℹ️  No new providers were added (they may already exist in your configuration)"
    fi

    # Display sign-up links
    echo
    echo "🔗 Sign up for API access:"
    printf '   Synthetic: %s\n' "$(link "https://synthetic.new/?referral=ugceNlJ08A3Eeww" "https://synthetic.new")"
    printf '   Alibaba Cloud Coding Plan: %s\n' "$(link "https://www.alibabacloud.com/campaign/benefits?referral_code=A92LUX" "https://alibabacloud.com/campaign/benefits")"
    echo
}

